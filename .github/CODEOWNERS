**/docker-compose.yml                      @hr-core/platform
**/.dockerignore                           @hr-core/platform
/.github/workflows/                        @hr-core/platform
/.github/actions/                          @hr-core/platform


# -----------------------------------------------------------------------------
# Tooling e config raiz — qualquer mudança aqui afeta o monorepo inteiro
# -----------------------------------------------------------------------------
