# Runtime
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# Auth Service — chave pública via JWKS (rotação automática)
AUTH_JWKS_URL=http://auth-service:4000/.well-known/jwks.json
AUTH_JWT_ISSUER=https://auth.hr-core.local
AUTH_JWT_AUDIENCE=hr-core

# Rate limit (in-memory por instância — substituir por Redis em produção)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# CORS
#   CORS_ORIGINS=""              -> CORS desabilitado (default)
#   CORS_ORIGINS="*"             -> qualquer origin (NUNCA usar em produção com credentials=true)
#   CORS_ORIGINS="a.com,b.com"   -> allowlist explícita
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# Swagger / OpenAPI
#   SWAGGER_ENABLED=true  -> expõe Swagger UI em SWAGGER_ROUTE_PREFIX (default /docs)
#   SWAGGER_ENABLED=false -> desliga (recomendado em produção se exposição pública)
SWAGGER_ENABLED=true
SWAGGER_ROUTE_PREFIX=/docs

# OpenTelemetry (tracing → Tempo/Jaeger via OTLP HTTP)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=api-gateway
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production,team=platform

# Downstream services
FUNCIONARIO_SERVICE_URL=http://funcionario-service:4001
FERIAS_SERVICE_URL=http://ferias-service:4002
AVALIACAO_SERVICE_URL=http://avaliacao-service:4003
FOLHA_PAGAMENTO_SERVICE_URL=http://folha-pagamento-service:4004
