# Runtime
NODE_ENV=development
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=info

# MongoDB — banco próprio do Auth Service
MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=hr-auth

# JWT
#   AUTH_JWT_ISSUER e AUTH_JWT_AUDIENCE devem casar com o que o api-gateway espera.
#   AUTH_PRIVATE_KEY_PATH aponta para uma chave RSA PKCS#8 PEM (gerada por
#     `openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048`).
#   Em NODE_ENV=development, se o arquivo não existir, uma chave in-memory é
#     gerada no boot (perdida a cada restart). Em production o boot falha hard.
AUTH_JWT_ISSUER=https://auth.hr-core.local
AUTH_JWT_AUDIENCE=hr-core
AUTH_PRIVATE_KEY_PATH=./keys/private.pem
AUTH_JWT_KID=auth-v1

# Lifespans
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=604800

# Argon-like difficulty pra scrypt (N=2^15 é equivalente a ~64MB de mem por hash;
# subir pra 2^16 dobra o custo; ajustar conforme servidor).
AUTH_SCRYPT_LOG_N=15
AUTH_SCRYPT_R=8
AUTH_SCRYPT_P=1

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# Swagger / OpenAPI
#   SWAGGER_ENABLED=true  -> expõe Swagger UI em SWAGGER_ROUTE_PREFIX (default /docs)
#   SWAGGER_ENABLED=false -> desliga (recomendado em produção se exposição pública)
SWAGGER_ENABLED=true
SWAGGER_ROUTE_PREFIX=/docs

# OpenTelemetry (tracing → Tempo/Jaeger via OTLP HTTP)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=auth
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318
