{
  "name": "hr-core",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma HR Core — base compartilhada para microserviços (Node.js + TypeScript + pnpm)",
  "type": "module",
  "engines": {
    "node": ">=22.11.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky && pnpm prepare:commit-template",
    "prepare:commit-template": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && git config commit.template .gitmessage.txt || true"
  },
  "lint-staged": {
    "*.{ts,js,cjs,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.8.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs"
    ]
  }
}
