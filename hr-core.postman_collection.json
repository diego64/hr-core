    {
      "name": "Errors (RFC 7807)",
      "description": "Cenários que validam o contrato de erro RFC 7807 (`application/problem+json`).",
      "item": [
        {
          "name": "401 — request sem Bearer token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/funcionarios",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "funcionarios"]
            },
            "description": "Auth desabilitada na request — gateway responde 401."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('status 401', function () { pm.response.to.have.status(401); });"]
              }
            }
          ],
          "response": []
        },
        {
          "name": "401 — token inválido",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "eyJhbGciOiJSUzI1NiJ9.invalid.signature",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/funcionarios",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "funcionarios"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('status 401', function () { pm.response.to.have.status(401); });"]
              }
            }
          ],
          "response": []
        },
        {
          "name": "404 — rota inexistente",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/this-route-does-not-exist",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "this-route-does-not-exist"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 404', function () { pm.response.to.have.status(404); });",
                  "pm.test('type categoriza como not-found', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.type).to.include('not-found');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "429 — rate limit (rodar várias vezes em sequência)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Use o **Runner** do Postman ou execute manualmente N vezes acima de `RATE_LIMIT_MAX` (default 100/min) para forçar o 429. O body deve seguir RFC 7807 com `type` apontando para `rate-limit`."
          },
          "response": []
        }
      ]
    }
