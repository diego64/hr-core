  "item": [
    {
      "name": "Auth Service (direto :4000)",
      "description": "Endpoints do auth-service. Atingem `{{auth_url}}` diretamente, sem passar pelo gateway. Usar para testar register/login/refresh/logout e baixar o JWKS.",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{auth_url}}/health", "host": ["{{auth_url}}"], "path": ["health"] }
          }
        },
        {
          "name": "GET /.well-known/jwks.json",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{auth_url}}/.well-known/jwks.json",
              "host": ["{{auth_url}}"],
              "path": [".well-known", "jwks.json"]
            },
            "description": "Lista de chaves públicas RSA usadas para verificar JWTs. Consumido pelo gateway via `createRemoteJWKSet`."
          }
        },
        {
          "name": "POST /auth/register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('access_token', body.accessToken);",
                  "  pm.collectionVariables.set('refresh_token', body.refreshToken);",
                  "  pm.test('access_token + refresh_token salvos', function () {",
                  "    pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
                  "    pm.expect(body.refreshToken).to.be.a('string').and.not.empty;",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"novo-usuario@hr-core.local\",\n  \"password\": \"senha-forte-aqui-123\"\n}"
            },
            "url": {
              "raw": "{{auth_url}}/auth/register",
              "host": ["{{auth_url}}"],
              "path": ["auth", "register"]
            },
            "description": "Cria um novo usuário (role default `USUARIO`) e já retorna um par de tokens. Email único — segunda chamada com mesmo email → 409 `email-already-taken`."
          }
        },
        {
          "name": "POST /auth/login (admin seed)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login admin retorna 200 + tokens', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.user.roles).to.include('ADMINISTRADOR');",
                  "  pm.collectionVariables.set('access_token', body.accessToken);",
                  "  pm.collectionVariables.set('refresh_token', body.refreshToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
            },
            "url": {
              "raw": "{{auth_url}}/auth/login",
              "host": ["{{auth_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Autentica como ADMINISTRADOR (do seed). Salva `access_token` e `refresh_token` em variáveis da collection."
          }
        },
        {
          "name": "POST /auth/login (coord seed)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login coord retorna 200 + tokens', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.user.roles).to.include('COORDENADOR');",
                  "  pm.collectionVariables.set('access_token', body.accessToken);",
                  "  pm.collectionVariables.set('refresh_token', body.refreshToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{coord_email}}\",\n  \"password\": \"{{coord_password}}\"\n}"
            },
            "url": {
              "raw": "{{auth_url}}/auth/login",
              "host": ["{{auth_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Autentica como COORDENADOR (do seed). Permissões intermediárias entre ADMINISTRADOR e USUARIO. Salva `access_token` e `refresh_token` em variáveis da collection."
          }
        },
        {
          "name": "POST /auth/login (user seed)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login user retorna 200 + tokens', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.user.roles).to.include('USUARIO');",
                  "  pm.collectionVariables.set('access_token', body.accessToken);",
                  "  pm.collectionVariables.set('refresh_token', body.refreshToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"password\": \"{{user_password}}\"\n}"
            },
            "url": {
              "raw": "{{auth_url}}/auth/login",
              "host": ["{{auth_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "POST /auth/refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('access_token', body.accessToken);",
                  "  pm.collectionVariables.set('refresh_token', body.refreshToken);",
                  "  pm.test('rotation: refresh_token foi substituído', function () {",
                  "    pm.expect(body.refreshToken).to.be.a('string').and.not.empty;",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{auth_url}}/auth/refresh",
              "host": ["{{auth_url}}"],
              "path": ["auth", "refresh"]
            },
            "description": "Rotaciona o refresh token. O token antigo é marcado como `usedAt`. Reapresentar o token antigo → 401 `refresh-token-reuse-detected` e revogação em cascata de TODOS os tokens do usuário."
          }
        },
        {
          "name": "POST /auth/logout",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{auth_url}}/auth/logout",
              "host": ["{{auth_url}}"],
              "path": ["auth", "logout"]
            },
            "description": "Revoga o refresh token informado. Idempotente — token inexistente/inválido retorna 204."
          }
        }
      ]
    },
